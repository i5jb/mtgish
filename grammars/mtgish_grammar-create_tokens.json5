    "AddCardtypes([Enchantment])": "",
    "SetCardtypes([Creature])": "",
    "SetCardtypes([Artifact])": "",
    "SetCardtypes([Enchantment])": "",
    "SetCardtypes([Enchantment, Creature])": "",

    "AddArtifactTypes([Food])": "",
    "SetArtifactTypes([Food])": "",
    "AddCreatureTypes([{{ZOMBIE}}])": "",
    "SetCreatureTypes([{{ZOMBIE}}])": "",

    "AddAbility([{{RULE}}])": "",
    "LosesAbility({{CHECK_HASABLE}})": "",
    "RemoveThisAbility": "",
    "AddAbilityFromEachExiledHasable({{CARDS_IN_EXILE}}, {{CHECK_HASABLE_LIST}})": "",

    "AddColor(SimpleColorList([{{SIMPLE_COLOR}}]))": "",
    "SetColor(SimpleColorList([{{SIMPLE_COLOR}}]))": "",
    "SetColor(SimpleColorList([{{SIMPLE_COLOR}}, {{SIMPLE_COLOR}}]))": "",
    "SetColor(Colorless)": "",

    "SetName({{QUOTED_NAMED_CARD}})": "",

    "SetPT({{PT}})": "",

    "SetLoyalty({{NUMBER}})": "",
