{
  "{{TOKEN_COPY_EFFECT}}": {
    "AddSupertypes([{{SUPERTYPE}}])": "",
    "RemoveSupertypes([{{SUPERTYPE}}])": "",

    "AddCardtypes([Artifact, Creature])": "",
    "AddCardtypes([Artifact])": "",
